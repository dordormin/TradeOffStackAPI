###
# SCRIPT DE PEUPLEMENT - Réservations et Maintenance
# Prérequis : Les utilisateurs (u001-u020) et équipements (e001-e040) doivent déjà exister.
###

@host = http://localhost:5053

### =========================================================================
### 0. CONNEXION DE L'ADMINISTRATEUR
### =========================================================================
# @name loginAdmin
POST {{host}}/api/auth/login
Content-Type: application/json

{ "email": "super.admin@trade.io", "password": "Password123!" }
> {% client.global.set("token", response.body.token); %}



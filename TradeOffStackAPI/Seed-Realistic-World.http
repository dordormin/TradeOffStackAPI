###
# SCRIPT DE PEUPLEMENT RÉALISTE
# Simule l'état d'une entreprise avec des actifs ayant un cycle de vie complet.
#
# ORDRE D'EXÉCUTION :
# 0. Créer l'Admin initial et récupérer son token.
# 1. Créer les Départements.
# 2. Créer les autres Utilisateurs et les assigner.
# 3. Créer tous les Équipements.
# 4. Créer les Réservations et Demandes de Maintenance pour simuler l'activité.
###

@host = http://localhost:5053

### =========================================================================
### 0. CRÉATION & CONNEXION DE L'ADMINISTRATEUR INITIAL
### =========================================================================
# @name createAndLoginAdmin
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "firstName": "Super",
  "lastName": "Admin",
  "email": "super.admin@trade.io",
  "password": "Password123!"
}
> {% client.global.set("token", response.body.token); %}


### =========================================================================
### 1. DÉPARTEMENTS (4)
### =========================================================================
# @name createDeptIT
POST {{host}}/api/department
Authorization: Bearer {{token}}
Content-Type: application/json

{ "name": "Technologie de l'Information", "description": "Support, Infrastructure et Développement" }
> {% client.global.set("deptIT_id", response.body.id); %}

###
# @name createDeptSales
POST {{host}}/api/department
Authorization: Bearer {{token}}
Content-Type: application/json

{ "name": "Ventes & Marketing", "description": "Acquisition client et communication" }
> {% client.global.set("deptSales_id", response.body.id); %}

###
# @name createDeptHR
POST {{host}}/api/department
Authorization: Bearer {{token}}
Content-Type: application/json

{ "name": "Ressources Humaines", "description": "Gestion du personnel et recrutement" }
> {% client.global.set("deptHR_id", response.body.id); %}

###
# @name createDeptExec
POST {{host}}/api/department
Authorization: Bearer {{token}}
Content-Type: application/json

{ "name": "Direction", "description": "Comité exécutif" }
> {% client.global.set("deptExec_id", response.body.id); %}


